{
  "name": "@operon/sdk",
  "version": "0.16.6",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "proto:gen": "mkdir -p src/generated && protoc --experimental_allow_proto3_optional --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=src/generated --ts_proto_opt=outputServices=nice-grpc,outputServices=generic-definitions,useExactTypes=false,esModuleInterop=true,forceLong=string --proto_path=../../proto ../../proto/operon/runtime.proto",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.public-api.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "ts-proto": "2.11.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.12.0",
    "long": "5.3.2",
    "nice-grpc": "2.1.16",
    "nice-grpc-common": "2.0.3",
    "protobufjs": "8.0.3"
  }
}
